[Unit]
Description=Bookshelf API (FastAPI + uvicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/book.tanxy.net
EnvironmentFile=/etc/bookshelf.env
ExecStart=/var/www/book.tanxy.net/.venv/bin/uvicorn api.main:app --host 127.0.0.1 --port 8001
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
